---
import BaseLayout from "./BaseLayout.astro";
// katex CSS is opt-in per post (import it from a post when you use math)

interface Props {
  title: string;
  summary: string;
  publishedAt: Date;
  updatedAt?: Date;
  tags: string[];
  readingTime: string;
  slug: string;
}

const { title, summary, publishedAt, updatedAt, tags, readingTime, slug } =
  Astro.props;

const fmt = (d: Date) =>
  d.toISOString().slice(0, 10);

// slug accepted for forward-compat (per-post OG image will be added later)
void slug;
---

<BaseLayout
  title={title}
  description={summary}
  type="article"
  publishedAt={publishedAt}
  updatedAt={updatedAt}
>
  <article class="post fade-up">
    <header class="post-header">
      <a href="/writing" class="back">← writing</a>
      <h1 class="post-title">{title}</h1>
      <p class="post-summary">{summary}</p>
      <div class="post-meta">
        <time datetime={publishedAt.toISOString()}>{fmt(publishedAt)}</time>
        {updatedAt && (
          <>
            <span class="dot">·</span>
            <span>updated {fmt(updatedAt)}</span>
          </>
        )}
        <span class="dot">·</span>
        <span>{readingTime}</span>
        {tags.length > 0 && (
          <>
            <span class="dot">·</span>
            <span class="tags">
              {tags.map((t) => <span class="tag">#{t}</span>)}
            </span>
          </>
        )}
      </div>
    </header>
    <div class="prose">
      <slot />
    </div>
    <footer class="post-footer">
      <a href="/writing" class="back">← back to writing</a>
    </footer>
  </article>

  <style>
    .post {
      max-width: 65ch;
      margin: 0 auto;
    }
    .post-header {
      margin-bottom: 2.5rem;
    }
    .back {
      color: var(--color-muted);
      font-size: 0.85rem;
      display: inline-block;
      margin-bottom: 1.5rem;
    }
    .back:hover {
      color: var(--color-accent);
    }
    .post-title {
      font-family: var(--font-mono);
      font-size: clamp(1.6rem, 4vw, 2.1rem);
      font-weight: 600;
      line-height: 1.2;
      letter-spacing: -0.02em;
      margin: 0 0 0.6rem;
    }
    .post-summary {
      color: var(--color-muted);
      font-family: var(--font-sans);
      font-size: 1rem;
      margin: 0 0 1rem;
      line-height: 1.5;
    }
    .post-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 0.4rem;
      align-items: center;
      color: var(--color-muted);
      font-size: 0.82rem;
    }
    .post-meta .dot {
      color: var(--color-faint);
    }
    .tags {
      display: inline-flex;
      gap: 0.4rem;
    }
    .tag {
      color: var(--color-accent-dim);
    }
    .post-footer {
      margin-top: 4rem;
      padding-top: 1.5rem;
      border-top: 1px solid var(--color-border);
    }
  </style>
</BaseLayout>
