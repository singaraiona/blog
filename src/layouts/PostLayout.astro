---
import BaseLayout from "./BaseLayout.astro";
// katex CSS is opt-in per post (import it from a post when you use math)

import {
  PERSPECTIVE_LABELS,
  PROJECT_LABELS,
  STEP_INFO,
} from "../lib/writing";

interface Props {
  title: string;
  summary: string;
  publishedAt: Date;
  updatedAt?: Date;
  tags: string[];
  readingTime: string;
  slug: string;
  project: keyof typeof PROJECT_LABELS;
  step: keyof typeof STEP_INFO;
  workPeriod: string;
  perspective: keyof typeof PERSPECTIVE_LABELS;
}

const {
  title,
  summary,
  publishedAt,
  updatedAt,
  tags,
  readingTime,
  slug,
  project,
  step,
  workPeriod,
  perspective,
} = Astro.props;

const fmt = (d: Date) =>
  d.toISOString().slice(0, 10);

const siteOrigin = Astro.site?.origin ?? "https://anton.kundenko.dev";
const postUrl = `${siteOrigin}/writing/${slug}/`;

const blogPostingSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "@id": postUrl,
  headline: title,
  description: summary,
  url: postUrl,
  datePublished: publishedAt.toISOString(),
  dateModified: (updatedAt ?? publishedAt).toISOString(),
  inLanguage: "en",
  keywords: tags.join(", "),
  author: {
    "@type": "Person",
    "@id": `${siteOrigin}/#person`,
    name: "Anton Kundenko",
    url: `${siteOrigin}/`,
  },
  publisher: {
    "@type": "Person",
    "@id": `${siteOrigin}/#person`,
    name: "Anton Kundenko",
  },
  mainEntityOfPage: { "@type": "WebPage", "@id": postUrl },
  isPartOf: {
    "@type": "Blog",
    "@id": `${siteOrigin}/writing`,
    name: "Anton Kundenko - Writing",
  },
});

const breadcrumbSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: `${siteOrigin}/` },
    {
      "@type": "ListItem",
      position: 2,
      name: "Writing",
      item: `${siteOrigin}/writing`,
    },
    { "@type": "ListItem", position: 3, name: title, item: postUrl },
  ],
});
---

<BaseLayout
  title={title}
  description={summary}
  type="article"
  publishedAt={publishedAt}
  updatedAt={updatedAt}
>
  <script type="application/ld+json" is:inline set:html={blogPostingSchema} />
  <script type="application/ld+json" is:inline set:html={breadcrumbSchema} />

  <article class="post fade-up">
    <header class="post-header">
      <a href="/writing" class="back">← writing</a>
      <h1 class="post-title">{title}</h1>
      <p class="post-summary">
        <span class="summary-label">summary:</span> {summary}
      </p>
      <div class="post-context">
        <span class="chip">{PROJECT_LABELS[project]}</span>
        <span class="chip">{STEP_INFO[step].title}</span>
        <span class="chip">work: {workPeriod}</span>
        <span class="chip">{PERSPECTIVE_LABELS[perspective]}</span>
      </div>
      <div class="post-meta">
        <time datetime={publishedAt.toISOString()}>{fmt(publishedAt)}</time>
        {updatedAt && (
          <>
            <span class="dot">·</span>
            <span>updated {fmt(updatedAt)}</span>
          </>
        )}
        <span class="dot">·</span>
        <span>{readingTime}</span>
        {tags.length > 0 && (
          <>
            <span class="dot">·</span>
            <span class="tags">
              {tags.map((t) => <span class="tag">#{t}</span>)}
            </span>
          </>
        )}
      </div>
    </header>
    <div class="prose">
      <slot />
    </div>
    <footer class="post-footer">
      <p class="byline">
        by <a href="/about" rel="author">Anton Kundenko</a>
        <span class="dot">·</span>
        <span class="byline-role">principal systems engineer</span>
      </p>
      <p class="byline-meta">
        author of RayforceDB, TeideDB, and the Rayfall language.
      </p>
      <p class="byline-links">
        <a href="/writing">more writing</a>
        <span class="dot">·</span>
        <a href="/rss.xml">rss feed</a>
        <span class="dot">·</span>
        <a href="/about">about</a>
      </p>
    </footer>
  </article>

  <style>
    .post {
      max-width: 65ch;
      margin: 0 auto;
    }
    .post-header {
      margin-bottom: 2.5rem;
    }
    .back {
      color: var(--color-muted);
      font-size: 0.85rem;
      display: inline-block;
      margin-bottom: 1.5rem;
    }
    .back:hover {
      color: var(--color-accent);
    }
    .post-title {
      font-family: var(--font-mono);
      font-size: clamp(1.6rem, 4vw, 2.1rem);
      font-weight: 600;
      line-height: 1.2;
      letter-spacing: -0.02em;
      margin: 0 0 0.6rem;
    }
    .post-summary {
      color: var(--color-muted);
      font-family: var(--font-sans);
      font-size: 1rem;
      margin: 0 0 1rem;
      line-height: 1.5;
    }
    .summary-label {
      font-family: var(--font-mono);
      font-size: 0.78rem;
      color: var(--color-accent-dim);
      letter-spacing: 0.02em;
      margin-right: 0.35rem;
      text-transform: lowercase;
    }
    .post-context {
      display: flex;
      flex-wrap: wrap;
      gap: 0.4rem;
      margin-bottom: 0.85rem;
    }
    .chip {
      font-size: 0.74rem;
      padding: 0.12rem 0.5rem;
      border: 1px solid var(--color-border);
      border-radius: 999px;
      color: var(--color-muted);
    }
    .post-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 0.4rem;
      align-items: center;
      color: var(--color-muted);
      font-size: 0.82rem;
    }
    .post-meta .dot {
      color: var(--color-faint);
    }
    .tags {
      display: inline-flex;
      gap: 0.4rem;
    }
    .tag {
      color: var(--color-accent-dim);
    }
    .post-footer {
      margin-top: 4rem;
      padding-top: 1.5rem;
      border-top: 1px solid var(--color-border);
      font-family: var(--font-mono);
      font-size: 0.84rem;
      color: var(--color-muted);
    }
    .post-footer .byline {
      margin: 0 0 0.4rem;
      color: var(--color-fg);
    }
    .post-footer .byline a {
      color: var(--color-fg);
    }
    .post-footer .byline a:hover {
      color: var(--color-accent);
    }
    .post-footer .byline-role {
      color: var(--color-muted);
    }
    .post-footer .byline-meta {
      margin: 0 0 0.6rem;
      color: var(--color-muted);
    }
    .post-footer .byline-links {
      margin: 0;
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      align-items: center;
      color: var(--color-muted);
    }
    .post-footer .byline-links a {
      color: var(--color-muted);
    }
    .post-footer .byline-links a:hover {
      color: var(--color-accent);
    }
    .post-footer .dot {
      color: var(--color-faint);
    }
  </style>
</BaseLayout>
