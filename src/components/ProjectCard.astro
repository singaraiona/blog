---
interface Props {
  title: string;
  href: string;
  tagline: string;
  blurb: string;
  chips: string[];
}

const { title, href, tagline, blurb, chips } = Astro.props;
---

<a class="project-card" href={href} target="_blank" rel="noopener noreferrer">
  <div class="header">
    <h3>{title}</h3>
    <span class="external" aria-hidden="true">↗</span>
  </div>
  <p class="tagline">{tagline}</p>
  <p class="blurb">{blurb}</p>
  <div class="chips">
    {chips.map((c) => <span class="chip">{c}</span>)}
  </div>
</a>

<style>
  .project-card {
    display: flex;
    flex-direction: column;
    padding: 1.1rem 1.2rem;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background: var(--color-surface);
    transition: border-color 160ms ease;
    color: var(--color-fg);
  }
  .project-card:hover {
    border-color: var(--color-accent-dim);
  }
  .header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 0.4rem;
  }
  h3 {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 1rem;
    color: var(--color-accent);
    font-weight: 600;
    letter-spacing: -0.01em;
  }
  .external {
    color: var(--color-muted);
    font-size: 0.85rem;
  }
  .project-card:hover .external {
    color: var(--color-accent);
  }
  .tagline {
    color: var(--color-fg);
    font-size: 0.86rem;
    line-height: 1.5;
    margin: 0 0 0.5rem;
  }
  .blurb {
    color: var(--color-muted);
    font-size: 0.8rem;
    line-height: 1.5;
    margin: 0;
    flex: 1;
  }
  .chips {
    margin-top: 0.85rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }
  .chip {
    font-size: 0.7rem;
    padding: 0.12rem 0.5rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    color: var(--color-accent-dim);
  }
</style>
