---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import Caret from "../components/Caret.astro";
import Section from "../components/Section.astro";
import PostCard from "../components/PostCard.astro";
import ProjectCard from "../components/ProjectCard.astro";
import {
  PERSPECTIVE_LABELS,
  PROJECT_LABELS,
} from "../lib/writing";

const posts = (await getCollection("writing", ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf())
  .slice(0, 4);

const projects = [
  {
    title: "RayforceDB",
    href: "https://rayforcedb.com/",
    tagline:
      "Embeddable C analytical database with a tiny language surface and years of engine iteration underneath it.",
    blurb:
      "The system that turned the ThePlatform ideas into a smaller, embeddable shape and later absorbed the Teide execution model.",
    chips: ["C", "Rayfall", "SIMD"],
  },
  {
    title: "ThePlatform",
    href: "https://theplatform.technology/",
    tagline:
      "Columnar time-series database and real-time analytics stack with the O programming language.",
    blurb:
      "Vector language inspired by APL/k with first-class tables, async reagents, and join-calculus concurrency.",
    chips: ["O", "Time-series", "Concurrency"],
  },
  {
    title: "TeideDB",
    href: "https://teidedb.com",
    tagline:
      "Analytical SQL surface and engine research line built around morsel-driven execution and columnar DAG planning.",
    blurb:
      "The engine work that later merged back into rayforce2 so the user-facing Rayfall surface could sit on the runtime I actually wanted.",
    chips: ["SQL", "Embedded", "Vectorized"],
  },
  {
    title: "Rayforce UI",
    href: "https://ui.rayforcedb.com/",
    tagline:
      "Native desktop GUI for RayforceDB with grids, charts, and a Rayfall REPL.",
    blurb:
      "C/C++ interface layer over the Rayforce runtime, built for zero-copy columnar rendering and direct analyst workflows without a browser stack.",
    chips: ["C++", "ImGui", "Zero-copy"],
  },
  {
    title: "Rayforce-Py",
    href: "https://py.rayforcedb.com/",
    tagline:
      "Pythonic ORM and query surface for RayforceDB with direct C API integration.",
    blurb:
      "Chainable table operations, plugin integrations, and native runtime access for analytical workloads from Python.",
    chips: ["Python", "ORM", "C API"],
  },
  {
    title: "Rayforce WASM SDK",
    href: "https://wasm.rayforcedb.com/",
    tagline:
      "Browser and JavaScript SDK for RayforceDB with zero-copy ArrayBuffer views.",
    blurb:
      "Interactive Rayfall REPL, tables, query builder, and TypedArray-backed vectors running on the WebAssembly build.",
    chips: ["WASM", "JavaScript", "TypedArray"],
  },
  {
    title: "raysense",
    href: "https://github.com/RayforceDB/raysense",
    tagline:
      "Architectural telemetry for repositories: cycles, coupling, complexity, and a single 0-100 health score.",
    blurb:
      "Scans the dependency graph and commit history, scores six A-F dimensions, and surfaces the result to humans, CI, and AI coding agents over MCP. Built on the rayforce runtime.",
    chips: ["Rust", "MCP", "Architecture"],
  },
  {
    title: "Teidelum",
    href: "https://lum.teidedb.com/",
    tagline:
      "Open-source knowledge infrastructure built on the Teide columnar engine.",
    blurb:
      "Syncs work tools, indexes content, and serves data to AI agents via MCP and applications via REST.",
    chips: ["MCP", "REST", "Knowledge"],
  },
  {
    title: "AxlDB",
    href: "/career#axl-experiment",
    tagline:
      "Shelved extraction experiment used to test whether Rayforce had another valid core shape.",
    blurb:
      "Worth keeping as a lab notebook because the negative result made the production system clearer.",
    chips: ["C", "Experiment", "Shelved"],
  },
  {
    title: "hyperbridge",
    href: "https://github.com/singaraiona/hyperbridge",
    tagline: "Fast multi-producer, multi-consumer unbounded channel for Rust, with async support.",
    blurb: "Standalone crate; used by ThePlatform and other Rust projects. Inspired by crossbeam.",
    chips: ["Rust", "MPMC", "Async"],
  },
];

const links = [
  { label: "github", href: "https://github.com/singaraiona" },
  {
    label: "linkedin",
    href: "https://www.linkedin.com/in/anton-kundenko-a22a3667/",
  },
  { label: "reddit", href: "https://www.reddit.com/user/het0ku/" },
  { label: "email", href: "mailto:anton.kundenko@gmail.com" },
  { label: "cv", href: "/resume.pdf" },
];
---

<BaseLayout>
  <section class="hero fade-up">
    <div class="hero-text">
      <h1 class="name">
        anton.kundenko<Caret />
      </h1>
      <p class="lede">
        principal systems engineer · architect of high-performance database
        systems · programming language creator.
        <span class="muted">
          18+ years building performance-critical infrastructure. creator of
          two original databases and their languages, in production at lynx
          trading - replacing kdb+/q.
        </span>
      </p>
      <div class="links">
        {links.map((l) => (
          <a
            href={l.href}
            target={l.href.startsWith("http") ? "_blank" : undefined}
            rel={l.href.startsWith("http") ? "noopener noreferrer" : undefined}
          >
            {l.label}
          </a>
        ))}
      </div>
    </div>
    <picture>
      <source srcset="/avatar.webp" type="image/webp" />
      <img
        src="/avatar.png"
        alt="Anton Kundenko"
        width="120"
        height="160"
        class="avatar"
        loading="eager"
        fetchpriority="high"
        decoding="async"
      />
    </picture>
  </section>

  <Section title="writing" href="/writing" rightLabel="all posts">
    <p class="writing-note">
      the archive reads best alongside the
      <a href="/career">career map</a>: each post is tied to the project phase
      it reflects.
    </p>
    {posts.length === 0 ? (
      <p class="empty">no posts yet - soon.</p>
    ) : (
      <div class="post-list">
        {posts.map((post) => (
          <PostCard
            href={`/writing/${post.id}`}
            title={post.data.title}
            summary={post.data.summary}
            publishedAt={post.data.publishedAt}
            context={[
              PROJECT_LABELS[post.data.project],
              `work: ${post.data.workPeriod}`,
              PERSPECTIVE_LABELS[post.data.perspective],
            ]}
            tags={post.data.tags}
          />
        ))}
      </div>
    )}
  </Section>

  <Section title="projects">
    <div class="project-grid">
      {projects.map((p) => <ProjectCard {...p} />)}
    </div>
  </Section>

  <Section title="contact">
    <p class="contact">
      open to collaboration, consulting, and performance audits.
    </p>
    <p class="contact">
      reach me at
      <a href="mailto:anton.kundenko@gmail.com">anton.kundenko@gmail.com</a>
      or on
      <a href="https://github.com/singaraiona" target="_blank" rel="noopener noreferrer">github</a>.
    </p>
  </Section>

  <style>
    .hero {
      display: flex;
      gap: 2rem;
      align-items: center;
      justify-content: space-between;
      padding: 2.5rem 0 1rem;
    }
    .hero-text {
      flex: 1;
      min-width: 0;
    }
    .name {
      font-family: var(--font-mono);
      font-size: clamp(1.6rem, 4.5vw, 2.4rem);
      font-weight: 700;
      letter-spacing: -0.025em;
      color: var(--color-fg);
      margin: 0 0 0.7rem;
      line-height: 1.05;
    }
    .lede {
      font-family: var(--font-mono);
      font-size: 0.95rem;
      line-height: 1.55;
      color: var(--color-fg);
      max-width: 56ch;
      margin: 0 0 1.2rem;
    }
    .lede .muted {
      color: var(--color-muted);
      display: block;
      margin-top: 0.3rem;
    }
    .links {
      display: flex;
      flex-wrap: wrap;
      gap: 0.4rem 1.2rem;
      font-size: 0.86rem;
      color: var(--color-muted);
    }
    .links a {
      color: var(--color-muted);
      position: relative;
    }
    .links a::before {
      content: "·";
      color: var(--color-faint);
      margin-right: 1.2rem;
      position: absolute;
      left: -1.4rem;
    }
    .links a:first-child::before {
      content: "";
    }
    .links a:hover {
      color: var(--color-accent);
    }
    .avatar {
      width: 120px;
      height: 160px;
      border-radius: 10px;
      border: 1px solid var(--color-border);
      object-fit: cover;
      object-position: 50% 18%;
      flex-shrink: 0;
    }
    @media (max-width: 640px) {
      .hero {
        flex-direction: column-reverse;
        align-items: flex-start;
        gap: 1.5rem;
      }
      .avatar {
        width: 84px;
        height: 112px;
      }
    }
    .post-list {
      display: flex;
      flex-direction: column;
    }
    .writing-note {
      color: var(--color-muted);
      font-size: 0.88rem;
      margin: 0 0 0.9rem;
      max-width: 62ch;
    }
    .writing-note a {
      color: var(--color-accent);
    }
    .writing-note a:hover {
      text-decoration: underline;
      text-decoration-color: var(--color-accent-dim);
      text-underline-offset: 3px;
    }
    .empty {
      color: var(--color-muted);
      font-size: 0.88rem;
    }
    .project-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1rem;
    }
    @media (max-width: 800px) {
      .project-grid {
        grid-template-columns: 1fr;
      }
    }
    .contact {
      color: var(--color-muted);
      font-size: 0.9rem;
      margin: 0 0 0.7rem;
    }
    .contact a {
      color: var(--color-accent);
    }
    .contact a:hover {
      text-decoration: underline;
      text-decoration-color: var(--color-accent-dim);
      text-underline-offset: 3px;
    }
  </style>
</BaseLayout>
